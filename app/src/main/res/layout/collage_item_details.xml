<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/pale_pink"
    android:padding="24dp"
    tools:context=".ui.DetailActivity">

    <Button
        android:id="@+id/backButton"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="← Back"
        android:textSize="16sp"
        android:backgroundTint="@color/dark_pink"
        android:textColor="@android:color/white"
        android:minWidth="0dp"
        android:paddingStart="12dp"
        android:paddingEnd="12dp"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintStart_toStartOf="parent" />

    <com.google.android.material.card.MaterialCardView
        android:id="@+id/detailCard"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_marginTop="16dp"
        app:cardCornerRadius="16dp"
        app:cardElevation="8dp"
        app:strokeWidth="1dp"
        android:backgroundTint="@android:color/white"
        app:layout_constraintTop_toBottomOf="@+id/backButton"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent">

        <ScrollView
            android:layout_width="match_parent"
            android:layout_height="match_parent">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:padding="24dp">

                <TextView
                    android:id="@+id/itemTitle"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:gravity="center"
                    android:text="Memory Title"
                    android:textColor="@color/dark_text"
                    android:textSize="28sp"
                    android:textStyle="bold"
                    android:layout_marginBottom="16dp" />

                <ImageView
                    android:id="@+id/itemImage"
                    android:layout_width="match_parent"
                    android:layout_height="220dp"
                    android:scaleType="centerCrop"
                    android:layout_marginBottom="24dp"
                    android:background="@color/light_gray_background"
                    android:contentDescription="Memory Image"
                    android:clipToOutline="true"
                    tools:src="@tools:sample/backgrounds/scenic" />

                <TextView
                    android:id="@+id/itemDate"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="12/11/2025"
                    android:textColor="@color/soft_pink"
                    android:textSize="18sp"
                    android:textStyle="bold"
                    android:paddingBottom="8dp" />

                <TextView
                    android:id="@+id/itemDescription"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="A wonderful day at the park, with a long, long story that should wrap nicely in this box!"
                    android:textColor="@color/dark_text"
                    android:textSize="16sp"
                    android:paddingBottom="8dp"
                    android:lineSpacingExtra="4dp"
                    android:layout_marginBottom="8dp" />

                <TextView
                    android:id="@+id/itemRating"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="Rating: 9/10"
                    android:textColor="@color/soft_pink"
                    android:textSize="18sp"
                    android:textStyle="bold"
                    android:paddingBottom="8dp" />

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:gravity="center"
                    android:layout_marginTop="32dp">

                    <Button
                        android:id="@+id/editButton"
                        android:layout_width="0dp"
                        android:layout_weight="1"
                        android:layout_height="wrap_content"
                        android:text="Edit"
                        android:textColor="@android:color/white"
                        android:backgroundTint="@color/dark_pink"
                        android:layout_marginEnd="8dp"
                        app:cornerRadius="10dp"/>

                    <Button
                        android:id="@+id/deleteButton"
                        android:layout_width="0dp"
                        android:layout_weight="1"
                        android:layout_height="wrap_content"
                        android:text="Delete"
                        android:textColor="@color/dark_pink"
                        android:backgroundTint="@color/light_pink_button"
                        android:layout_marginStart="8dp"
                        app:cornerRadius="10dp"/>

                </LinearLayout>

            </LinearLayout>
        </ScrollView>
    </com.google.android.material.card.MaterialCardView>

</androidx.constraintlayout.widget.ConstraintLayout>